# Release checkouts must have one worktree representation on every runner.
# This overrides a host-wide core.autocrlf=true without weakening dirty checks.
* text=auto eol=lf

# Preserve upstream legal texts byte-for-byte without treating their original
# line-ending whitespace as a source-formatting error.
/release-licenses/** -text -whitespace
# This generated aggregate contains an upstream RST title underline that Git
# otherwise misidentifies as a merge-conflict marker during `git diff --check`.
/release-licenses/PYTHON-LICENSES.txt -diff
