# 苏小有 backend configuration

# Required: OpenRouter API key
SUXIAOYOU_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Local OpenAI-compatible endpoint (optional)
# SUXIAOYOU_LOCAL_BASE_URL=http://localhost:11434/v1

# Database (default: SQLite in ./data/)
# SUXIAOYOU_DATABASE_URL=sqlite+aiosqlite:///./data/suxiaoyou.db

# Server
# SUXIAOYOU_HOST=0.0.0.0
# SUXIAOYOU_PORT=8000
# SUXIAOYOU_DEBUG=false

# Project directory (default: current directory)
# SUXIAOYOU_PROJECT_DIR=.
